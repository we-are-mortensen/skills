---
import BaseLayout from '@/layouts/BaseLayout.astro';

const modules = import.meta.glob('./**/*.astro', { eager: true });

const pages = Object.keys(modules)
  .map((filePath) => {
    let href = filePath
      .replace(/^\.\//, '/')
      .replace(/\.astro$/, '')
      .replace(/\/index$/, '');
    if (href === '') href = '/';
    return href;
  })
  .filter((href) => href !== '/')
  .sort();

const titleize = (segment: string) =>
  segment
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');

const formatLabel = (href: string) => {
  const segments = href.replace(/^\//, '').split('/');
  return titleize(segments[segments.length - 1]);
};
---
<BaseLayout title="Tech Barcelona — Wireframes">
  <main id="main" class="container-fluid py-16">
    <h1 class="text-2xl md:text-3xl font-semibold text-lo-text">Tech Barcelona — Wireframes</h1>
    <p class="mt-4 text-lo-text-muted">
      Scaffold ready. Start the first lo-fi page with the <code>mortensen-design</code> skill in mode A.
    </p>

    <section class="mt-12">
      <h2 class="text-xs uppercase tracking-widest text-lo-text-muted">Index</h2>
      <ul class="mt-4 border-t border-lo-border">
        {pages.map((href) => {
          const depth = href.split('/').length - 2;
          return (
            <li class="border-b border-lo-border">
              <a
                href={href}
                class="flex items-baseline gap-4 py-3 text-lo-text hover:text-lo-text-muted"
                style={`padding-left: ${depth * 1.5}rem`}
              >
                <span class="flex-1 font-medium">{formatLabel(href)}</span>
                <span class="text-sm text-lo-text-muted">{href}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  </main>
</BaseLayout>
